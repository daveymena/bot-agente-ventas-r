# ===== VentaFlow — Sistema de Ventas Automatizado =====

# PostgreSQL
DATABASE_URL=postgresql://ventaflow:ventaflow_secret@ventaflow-db:5432/ventaflow
POSTGRES_PASSWORD=change_me_in_production

# Backend
NODE_ENV=production
PORT=8080

# AI Provider (configurable también desde la UI: /ai-providers)
# Opciones: ollama | groq | openrouter | openai | anthropic | gemini
AI_PROVIDER=ollama
AI_MODEL=qwen2.5:1.5b
AI_API_KEY=
OLLAMA_URL=https://n8n-ollama.ginee6.easypanel.host
