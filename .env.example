# ===== VentaFlow — Sistema de Ventas Automatizado =====

# ----- Servidor -----
NODE_ENV=production
PORT=8080

# ----- PostgreSQL -----
DATABASE_URL=postgresql://ventaflow:ventaflow_secret@ventaflow-db:5432/ventaflow
POSTGRES_PASSWORD=change_me_in_production

# ----- AI Provider -----
# Configurable también desde la UI: /ai-providers
# Opciones: ollama | groq | openrouter | openai | anthropic | gemini | github
AI_PROVIDER=github
AI_MODEL=gpt-4o-mini
AI_API_KEY=
OLLAMA_URL=https://n8n-ollama.ginee6.easypanel.host

# Fallback (si el principal falla)
AI_FALLBACK_ENABLED=true
AI_FALLBACK_PROVIDER=ollama

# ----- Pagos: Transferencia local Colombia -----
TRANSFER_NEQUI=
TRANSFER_DAVIPLATA=
TRANSFER_BANCOLOMBIA=
TRANSFER_NAME=

# ----- Pagos: MercadoPago -----
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_ACCESS_TOKEN=

# ----- Pagos: PayPal -----
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# ----- Pagos: Stripe (opcional internacional) -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ----- Notificaciones SMTP (alertas de venta al admin) -----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# ----- Anti-Ban (delays de WhatsApp) -----
TYPING_DELAY_MIN=800
TYPING_DELAY_MAX=2000
READ_RECEIPT_DELAY=500

# ----- WhatsApp -----
# Carpeta donde se guardan las credenciales de Baileys
BAILEYS_AUTH_DIR=./.baileys-auth
