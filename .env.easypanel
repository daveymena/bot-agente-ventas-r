# ===== VentaFlow — Configuración para EasyPanel =====

# ----- Servidor -----
NODE_ENV=production
PORT=8080

# ----- PostgreSQL (Base de datos de EasyPanel) -----
# Reemplazar con los valores de tu base de datos de EasyPanel
DATABASE_URL=postgres://postgres:6715320@79.143.187.160:5433/tecnovariedades?sslmode=disable

# Usuario y contraseña de PostgreSQL (para docker-compose local)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=6715320
POSTGRES_DB=tecnovariedades

# ----- AI Provider -----
# Configurable también desde la UI: /ai-providers
AI_PROVIDER=ollama
AI_MODEL=qwen2.5:1.5b
AI_API_KEY=
OLLAMA_URL=https://n8n-ollama.ginee6.easypanel.host

# Fallback (si el principal falla)
AI_FALLBACK_ENABLED=true
AI_FALLBACK_PROVIDER=ollama

# ----- Pagos: Transferencia local Colombia -----
TRANSFER_NEQUI=
TRANSFER_DAVIPLATA=
TRANSFER_BANCOLOMBIA=
TRANSFER_NAME=

# ----- Pagos: MercadoPago -----
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_ACCESS_TOKEN=

# ----- Pagos: PayPal -----
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# ----- Pagos: Stripe (opcional internacional) -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ----- Notificaciones SMTP (alertas de venta al admin) -----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# ----- Anti-Ban (delays de WhatsApp) -----
TYPING_DELAY_MIN=800
TYPING_DELAY_MAX=2000
READ_RECEIPT_DELAY=500

# ----- WhatsApp -----
# Carpeta donde se guardan las credenciales de Baileys
BAILEYS_AUTH_DIR=./.baileys-auth

# ----- Multi-tenant (preparado para SaaS futuro) -----
# TENANT_ID se puede usar para separar datos por cliente
# TENANT_ID=default
